{
  "name": "@avibe/show-runtime",
  "version": "0.0.0",
  "description": "Managed Vite runtime for Vibe Remote Show Pages.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "avibe-show-runtime": "./dist/cli.js"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-annotation-bootstrap.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@avibe/show-sdk": "0.0.0",
    "@avibe/show-ui": "0.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^5.1.1",
    "esbuild": "^0.27.0",
    "tailwindcss": "^4.3.2",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0"
  },
  "license": "MIT"
}
