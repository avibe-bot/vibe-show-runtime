{
  "name": "vibe-show-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Runtime packages for interactive Vibe Remote Show Pages.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avibe-bot/vibe-show-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/avibe-bot/vibe-show-runtime/issues"
  },
  "homepage": "https://github.com/avibe-bot/vibe-show-runtime#readme",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @avibe/show-sdk && npm run build -w @avibe/show-ui && npm run build -w @avibe/show-runtime && npm run build -w @avibe/show-example-animation-showcase && npm run build -w @avibe/show-example-service-handler && npm run build -w @avibe/show-example-shadcn-alias",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run build && npm run typecheck",
    "bundle:vibe-remote": "node scripts/bundle-vibe-remote.mjs",
    "smoke": "node scripts/smoke-runtime.mjs"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "keywords": [
    "vibe-remote",
    "show-page",
    "vite",
    "react",
    "shadcn"
  ],
  "license": "MIT"
}
